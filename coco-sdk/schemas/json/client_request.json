    "ElicitationResolveParams": {
      "description": "Params for `elicitation/resolve`.\n\nSent client→server in response to a prior `ServerRequest` that asked the client to collect structured input on behalf of an MCP server (form values, OAuth tokens, etc.). The client populates `values` with the user's input and sets `approved=true`, or sets `approved=false` to reject the elicitation.\n\nTS reference: `SDKControlElicitationRequestSchema` (controlSchemas.ts) — TS uses a single bidirectional message that carries both request and response shapes; coco-rs splits them into a `ServerRequest` for the ask and this params struct for the reply.",
      "type": "object",
      "required": [
        "approved",
        "mcp_server_name",
        "request_id"
      ],
      "properties": {
        "approved": {
          "description": "Whether the user approved the elicitation. If `false`, `values` is ignored and the MCP server sees a rejection.",
          "type": "boolean"
        },
        "mcp_server_name": {
          "description": "Which MCP server the elicitation originated from. Echoed back so the agent can route the resolution to the right connection.",
          "type": "string"
        },
        "request_id": {
          "description": "Correlation id matching the `ServerRequest` the agent sent.",
          "type": "string"
        },
        "values": {
          "description": "The collected field values keyed by field name. Each value is an opaque JSON payload so typed/untyped fields share the wire format. Empty when `approved=false`.",
          "default": {},
          "type": "object",
          "additionalProperties": true
        }
      }
    },
