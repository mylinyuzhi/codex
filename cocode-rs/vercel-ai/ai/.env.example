# vercel-ai Integration Test Configuration
#
# Copy this file to `.env.test` (or `.env`) and fill in your API keys.
# Tests will gracefully skip providers that are not configured.
#
# Loading priority:
#   1. VERCEL_AI_TEST_ENV_FILE env var (custom path)
#   2. .env.test (in this directory)
#   3. .env (in this directory)

# ============================================================================
# OpenAI
# ============================================================================
VERCEL_AI_TEST_OPENAI_API_KEY=
VERCEL_AI_TEST_OPENAI_MODEL=gpt-4o-mini
# VERCEL_AI_TEST_OPENAI_BASE_URL=          # Optional: custom endpoint
# VERCEL_AI_TEST_OPENAI_CAPABILITIES=text,streaming,tools,vision,cross_provider

# ============================================================================
# Anthropic
# ============================================================================
VERCEL_AI_TEST_ANTHROPIC_API_KEY=
VERCEL_AI_TEST_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# VERCEL_AI_TEST_ANTHROPIC_BASE_URL=       # Optional: custom endpoint
# VERCEL_AI_TEST_ANTHROPIC_CAPABILITIES=text,streaming,tools,vision,cross_provider

# ============================================================================
# Google Generative AI (Gemini)
# ============================================================================
VERCEL_AI_TEST_GOOGLE_API_KEY=
VERCEL_AI_TEST_GOOGLE_MODEL=gemini-2.0-flash
# VERCEL_AI_TEST_GOOGLE_BASE_URL=          # Optional: custom endpoint
# VERCEL_AI_TEST_GOOGLE_CAPABILITIES=text,streaming,tools,vision,cross_provider

# ============================================================================
# Global Settings
# ============================================================================
# Restrict which test categories run for ALL providers (comma-separated).
# Available: text, streaming, tools, vision, cross_provider
# Default: all enabled
# VERCEL_AI_TEST_CAPABILITIES=text,streaming,tools
