    {
      "description": "Rewind completed — TUI truncates messages and restores input state. coco-rs extension: UI-only because it carries TUI-specific identifiers for message truncation and input repopulation. Out-of-band from the design's `rewind/completed` ServerNotification which carries protocol metadata only.",
      "type": "object",
      "required": [
        "files_changed",
        "target_message_id",
        "type"
      ],
      "properties": {
        "files_changed": {
          "description": "Number of files restored (0 if conversation-only).",
          "type": "integer",
          "format": "int32"
        },
        "target_message_id": {
          "description": "UUID of the target user message. Empty = code-only rewind.",
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "rewind_completed"
          ]
        }
      }
    }
