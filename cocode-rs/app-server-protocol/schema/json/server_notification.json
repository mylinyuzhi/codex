{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServerNotification",
  "description": "Events emitted by the server to all connected clients.\n\nThe `method` field uses slash-delimited paths (e.g. `\"turn/started\"`) following the codex-rs convention for JSON-RPC-style routing.",
  "oneOf": [
    {
      "description": "A new session has been created.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "session/started"
          ]
        },
        "params": {
          "$ref": "#/definitions/SessionStartedParams"
        }
      }
    },
    {
      "description": "A new turn has started (prompt sent to model).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "turn/started"
          ]
        },
        "params": {
          "$ref": "#/definitions/TurnStartedParams"
        }
      }
    },
    {
      "description": "A turn has completed successfully.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "turn/completed"
          ]
        },
        "params": {
          "$ref": "#/definitions/TurnCompletedParams"
        }
      }
    },
    {
      "description": "A turn has failed.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "turn/failed"
          ]
        },
        "params": {
          "$ref": "#/definitions/TurnFailedParams"
        }
      }
    },
    {
      "description": "A new item has been created (typically in-progress).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "item/started"
          ]
        },
        "params": {
          "$ref": "#/definitions/ItemEventParams"
        }
      }
    },
    {
      "description": "An existing item has been updated (e.g. output appended).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "item/updated"
          ]
        },
        "params": {
          "$ref": "#/definitions/ItemEventParams"
        }
      }
    },
    {
      "description": "An item has reached a terminal state (completed or failed).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "item/completed"
          ]
        },
        "params": {
          "$ref": "#/definitions/ItemEventParams"
        }
      }
    },
    {
      "description": "Incremental assistant text.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "agentMessage/delta"
          ]
        },
        "params": {
          "$ref": "#/definitions/AgentMessageDeltaParams"
        }
      }
    },
    {
      "description": "Incremental reasoning / thinking text.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "reasoning/delta"
          ]
        },
        "params": {
          "$ref": "#/definitions/ReasoningDeltaParams"
        }
      }
    },
    {
      "description": "A sub-agent has been spawned.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "subagent/spawned"
          ]
        },
        "params": {
          "$ref": "#/definitions/SubagentSpawnedParams"
        }
      }
    },
    {
      "description": "A sub-agent has completed.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "subagent/completed"
          ]
        },
        "params": {
          "$ref": "#/definitions/SubagentCompletedParams"
        }
      }
    },
    {
      "description": "A sub-agent has been moved to background execution.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "subagent/backgrounded"
          ]
        },
        "params": {
          "$ref": "#/definitions/SubagentBackgroundedParams"
        }
      }
    },
    {
      "description": "MCP server startup status.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "mcp/startupStatus"
          ]
        },
        "params": {
          "$ref": "#/definitions/McpStartupStatusParams"
        }
      }
    },
    {
      "description": "MCP startup completed (all servers attempted).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "mcp/startupComplete"
          ]
        },
        "params": {
          "$ref": "#/definitions/McpStartupCompleteParams"
        }
      }
    },
    {
      "description": "Context was compacted to stay within window limits.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "context/compacted"
          ]
        },
        "params": {
          "$ref": "#/definitions/ContextCompactedParams"
        }
      }
    },
    {
      "description": "Context usage is approaching limits.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "context/usageWarning"
          ]
        },
        "params": {
          "$ref": "#/definitions/ContextUsageWarningParams"
        }
      }
    },
    {
      "description": "A non-fatal error occurred.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "error"
          ]
        },
        "params": {
          "$ref": "#/definitions/ErrorNotificationParams"
        }
      }
    },
    {
      "description": "API rate limit information.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "rateLimit"
          ]
        },
        "params": {
          "$ref": "#/definitions/RateLimitParams"
        }
      }
    }
  ],
  "definitions": {
    "AgentMessageDeltaParams": {
      "description": "Parameters for `agentMessage/delta`.",
      "type": "object",
      "required": [
        "delta",
        "item_id",
        "turn_id"
      ],
      "properties": {
        "delta": {
          "description": "Incremental text content.",
          "type": "string"
        },
        "item_id": {
          "description": "Item identifier of the message being streamed.",
          "type": "string"
        },
        "turn_id": {
          "description": "Turn identifier.",
          "type": "string"
        }
      }
    },
    "ContextCompactedParams": {
      "description": "Parameters for `context/compacted`.",
      "type": "object",
      "required": [
        "removed_messages",
        "summary_tokens"
      ],
      "properties": {
        "removed_messages": {
          "description": "Messages removed during compaction.",
          "type": "integer",
          "format": "int32"
        },
        "summary_tokens": {
          "description": "Tokens in the compacted summary.",
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "ContextUsageWarningParams": {
      "description": "Parameters for `context/usageWarning`.",
      "type": "object",
      "required": [
        "estimated_tokens",
        "percent_left",
        "warning_threshold"
      ],
      "properties": {
        "estimated_tokens": {
          "description": "Current estimated token count.",
          "type": "integer",
          "format": "int32"
        },
        "percent_left": {
          "description": "Percentage of context remaining.",
          "type": "number",
          "format": "double"
        },
        "warning_threshold": {
          "description": "Warning threshold.",
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "ErrorNotificationParams": {
      "description": "Parameters for `error`.",
      "type": "object",
      "required": [
        "message"
      ],
      "properties": {
        "category": {
          "description": "Error category (e.g. \"api\", \"tool\", \"internal\").",
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "description": "Error message.",
          "type": "string"
        },
        "retryable": {
          "description": "Whether the error is retryable.",
          "default": false,
          "type": "boolean"
        }
      }
    },
    "FileChange": {
      "description": "A single file change within a `FileChangeItem`.",
      "type": "object",
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "description": "Kind of change.",
          "allOf": [
            {
              "$ref": "#/definitions/FileChangeKind"
            }
          ]
        },
        "path": {
          "description": "File path (relative or absolute).",
          "type": "string"
        }
      }
    },
    "FileChangeKind": {
      "description": "Kind of file modification.",
      "oneOf": [
        {
          "description": "New file created.",
          "type": "string",
          "enum": [
            "add"
          ]
        },
        {
          "description": "Existing file deleted.",
          "type": "string",
          "enum": [
            "delete"
          ]
        },
        {
          "description": "Existing file modified.",
          "type": "string",
          "enum": [
            "update"
          ]
        }
      ]
    },
    "ItemEventParams": {
      "description": "Parameters for item lifecycle events.",
      "type": "object",
      "required": [
        "item"
      ],
      "properties": {
        "item": {
          "description": "The item (with current state).",
          "allOf": [
            {
              "$ref": "#/definitions/ThreadItem"
            }
          ]
        }
      }
    },
    "ItemStatus": {
      "description": "Lifecycle status of a thread item.",
      "oneOf": [
        {
          "description": "Operation is running.",
          "type": "string",
          "enum": [
            "in_progress"
          ]
        },
        {
          "description": "Operation finished successfully.",
          "type": "string",
          "enum": [
            "completed"
          ]
        },
        {
          "description": "Operation failed.",
          "type": "string",
          "enum": [
            "failed"
          ]
        },
        {
          "description": "Tool was declined by user or permission system.",
          "type": "string",
          "enum": [
            "declined"
          ]
        }
      ]
    },
    "McpServerFailure": {
      "description": "Info about a failed MCP server startup.",
      "type": "object",
      "required": [
        "error",
        "name"
      ],
      "properties": {
        "error": {
          "description": "Error message.",
          "type": "string"
        },
        "name": {
          "description": "Server name.",
          "type": "string"
        }
      }
    },
    "McpServerInfoParams": {
      "description": "Info about a successfully started MCP server.",
      "type": "object",
      "required": [
        "name",
        "tool_count"
      ],
      "properties": {
        "name": {
          "description": "Server name.",
          "type": "string"
        },
        "tool_count": {
          "description": "Number of tools provided.",
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "McpStartupCompleteParams": {
      "description": "Parameters for `mcp/startupComplete`.",
      "type": "object",
      "required": [
        "failed",
        "servers"
      ],
      "properties": {
        "failed": {
          "description": "Failed servers.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/McpServerFailure"
          }
        },
        "servers": {
          "description": "Successfully started servers.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/McpServerInfoParams"
          }
        }
      }
    },
    "McpStartupStatusParams": {
      "description": "Parameters for `mcp/startupStatus`.",
      "type": "object",
      "required": [
        "server",
        "status"
      ],
      "properties": {
        "server": {
          "description": "Server name.",
          "type": "string"
        },
        "status": {
          "description": "Status description.",
          "type": "string"
        }
      }
    },
    "McpToolCallError": {
      "description": "Error from a failed MCP tool call.",
      "type": "object",
      "required": [
        "message"
      ],
      "properties": {
        "message": {
          "description": "Error message.",
          "type": "string"
        }
      }
    },
    "McpToolCallResult": {
      "description": "Successful result from an MCP tool call.",
      "type": "object",
      "required": [
        "content"
      ],
      "properties": {
        "content": {
          "description": "Content blocks returned by the MCP server.",
          "type": "array",
          "items": true
        },
        "structured_content": {
          "description": "Structured content (if provided by MCP server)."
        }
      }
    },
    "RateLimitParams": {
      "description": "Parameters for `rateLimit`.",
      "type": "object",
      "required": [
        "info"
      ],
      "properties": {
        "info": {
          "description": "Rate limit details."
        }
      }
    },
    "ReasoningDeltaParams": {
      "description": "Parameters for `reasoning/delta`.",
      "type": "object",
      "required": [
        "delta",
        "item_id",
        "turn_id"
      ],
      "properties": {
        "delta": {
          "description": "Incremental reasoning text.",
          "type": "string"
        },
        "item_id": {
          "description": "Item identifier of the reasoning block.",
          "type": "string"
        },
        "turn_id": {
          "description": "Turn identifier.",
          "type": "string"
        }
      }
    },
    "SessionStartedParams": {
      "description": "Parameters for `session/started`.",
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "description": "Session identifier.",
          "type": "string"
        }
      }
    },
    "SubagentBackgroundedParams": {
      "description": "Parameters for `subagent/backgrounded`.",
      "type": "object",
      "required": [
        "agent_id",
        "output_file"
      ],
      "properties": {
        "agent_id": {
          "description": "Agent identifier.",
          "type": "string"
        },
        "output_file": {
          "description": "Path to the output file for monitoring.",
          "type": "string"
        }
      }
    },
    "SubagentCompletedParams": {
      "description": "Parameters for `subagent/completed`.",
      "type": "object",
      "required": [
        "agent_id",
        "result"
      ],
      "properties": {
        "agent_id": {
          "description": "Agent identifier.",
          "type": "string"
        },
        "result": {
          "description": "Agent result text.",
          "type": "string"
        }
      }
    },
    "SubagentSpawnedParams": {
      "description": "Parameters for `subagent/spawned`.",
      "type": "object",
      "required": [
        "agent_id",
        "agent_type",
        "description"
      ],
      "properties": {
        "agent_id": {
          "description": "Agent identifier.",
          "type": "string"
        },
        "agent_type": {
          "description": "Agent type.",
          "type": "string"
        },
        "color": {
          "description": "Display color hint.",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "description": "Short description.",
          "type": "string"
        }
      }
    },
    "ThreadItem": {
      "description": "A discrete operation within a turn.",
      "type": "object",
      "oneOf": [
        {
          "description": "Assistant text response.",
          "type": "object",
          "required": [
            "text",
            "type"
          ],
          "properties": {
            "text": {
              "description": "Accumulated text so far.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "agent_message"
              ]
            }
          }
        },
        {
          "description": "Extended thinking / reasoning output.",
          "type": "object",
          "required": [
            "text",
            "type"
          ],
          "properties": {
            "text": {
              "description": "Accumulated reasoning text.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "reasoning"
              ]
            }
          }
        },
        {
          "description": "Shell command execution (Bash tool).",
          "type": "object",
          "required": [
            "aggregated_output",
            "command",
            "status",
            "type"
          ],
          "properties": {
            "aggregated_output": {
              "description": "Combined stdout + stderr output.",
              "type": "string"
            },
            "command": {
              "description": "The command string.",
              "type": "string"
            },
            "exit_code": {
              "description": "Process exit code (None while running).",
              "type": [
                "integer",
                "null"
              ],
              "format": "int32"
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "command_execution"
              ]
            }
          }
        },
        {
          "description": "File changes (Edit / Write / apply-patch tools).",
          "type": "object",
          "required": [
            "changes",
            "status",
            "type"
          ],
          "properties": {
            "changes": {
              "description": "Individual file changes.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/FileChange"
              }
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "file_change"
              ]
            }
          }
        },
        {
          "description": "MCP tool invocation.",
          "type": "object",
          "required": [
            "server",
            "status",
            "tool",
            "type"
          ],
          "properties": {
            "arguments": {
              "description": "Tool arguments.",
              "default": null
            },
            "error": {
              "description": "Error info (if failed).",
              "anyOf": [
                {
                  "$ref": "#/definitions/McpToolCallError"
                },
                {
                  "type": "null"
                }
              ]
            },
            "result": {
              "description": "Result content (if completed successfully).",
              "anyOf": [
                {
                  "$ref": "#/definitions/McpToolCallResult"
                },
                {
                  "type": "null"
                }
              ]
            },
            "server": {
              "description": "MCP server name.",
              "type": "string"
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "tool": {
              "description": "Tool name.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "mcp_tool_call"
              ]
            }
          }
        },
        {
          "description": "Web search or web fetch.",
          "type": "object",
          "required": [
            "query",
            "status",
            "type"
          ],
          "properties": {
            "query": {
              "description": "Search query or URL.",
              "type": "string"
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "web_search"
              ]
            }
          }
        },
        {
          "description": "Sub-agent spawned via Agent/Task tool.",
          "type": "object",
          "required": [
            "agent_id",
            "agent_type",
            "description",
            "status",
            "type"
          ],
          "properties": {
            "agent_id": {
              "description": "Agent identifier.",
              "type": "string"
            },
            "agent_type": {
              "description": "Agent type (e.g., \"general-purpose\", \"Explore\").",
              "type": "string"
            },
            "description": {
              "description": "Short description of the agent's task.",
              "type": "string"
            },
            "is_background": {
              "description": "Whether the agent is running in background.",
              "default": false,
              "type": "boolean"
            },
            "result": {
              "description": "Agent result (set on completion).",
              "type": [
                "string",
                "null"
              ]
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "subagent"
              ]
            }
          }
        },
        {
          "description": "Catch-all for other built-in tools (Read, Glob, Grep, etc.).",
          "type": "object",
          "required": [
            "status",
            "tool",
            "type"
          ],
          "properties": {
            "input": {
              "description": "Tool input (JSON).",
              "default": null
            },
            "is_error": {
              "description": "Whether the tool returned an error.",
              "default": false,
              "type": "boolean"
            },
            "output": {
              "description": "Tool output.",
              "type": [
                "string",
                "null"
              ]
            },
            "status": {
              "description": "Current status.",
              "allOf": [
                {
                  "$ref": "#/definitions/ItemStatus"
                }
              ]
            },
            "tool": {
              "description": "Tool name.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "tool_call"
              ]
            }
          }
        },
        {
          "description": "Non-fatal error surfaced as an item.",
          "type": "object",
          "required": [
            "message",
            "type"
          ],
          "properties": {
            "message": {
              "description": "Error message.",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "error"
              ]
            }
          }
        }
      ],
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "description": "Unique identifier for this item.",
          "type": "string"
        }
      }
    },
    "TurnCompletedParams": {
      "description": "Parameters for `turn/completed`.",
      "type": "object",
      "required": [
        "turn_id",
        "usage"
      ],
      "properties": {
