# cocode-api Integration Test Configuration
#
# Copy this file to `.env.test` and fill in your API keys.
# Tests will gracefully skip providers that are not configured.
#
# Run: cargo test -p cocode-api --test live -- --test-threads=1
#
# Two configuration modes per provider:
#
# MODE 1: Flat env vars (simple)
#   Set individual fields. MODEL and API_KEY are required.
#
# MODE 2: Full JSON (advanced)
#   Set COCODE_API_TEST_{PROVIDER}_CONFIG to a full ProviderInfo JSON string.
#   When set, all flat env vars for that provider are ignored (except MODEL).

# ============================================================================
# OpenAI (Responses API by default)
# ============================================================================
COCODE_API_TEST_OPENAI_API_KEY=
COCODE_API_TEST_OPENAI_MODEL=gpt-4o-mini
# COCODE_API_TEST_OPENAI_BASE_URL=https://api.openai.com/v1
# COCODE_API_TEST_OPENAI_WIRE_API=responses
# COCODE_API_TEST_OPENAI_CAPABILITIES=text,streaming,tools,cross_provider

# ============================================================================
# OpenAI Chat (Chat Completions API variant)
# ============================================================================
# Uses same credentials as OpenAI by default (falls back to OPENAI_ vars).
# Override with OPENAI_CHAT_ prefix for different config.
# COCODE_API_TEST_OPENAI_CHAT_API_KEY=
# COCODE_API_TEST_OPENAI_CHAT_MODEL=gpt-4o-mini
# COCODE_API_TEST_OPENAI_CHAT_WIRE_API=chat

# ============================================================================
# Anthropic
# ============================================================================
COCODE_API_TEST_ANTHROPIC_API_KEY=
COCODE_API_TEST_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# COCODE_API_TEST_ANTHROPIC_BASE_URL=https://api.anthropic.com
# COCODE_API_TEST_ANTHROPIC_CAPABILITIES=text,streaming,tools,cross_provider

# ============================================================================
# Google Gemini
# ============================================================================
COCODE_API_TEST_GEMINI_API_KEY=
COCODE_API_TEST_GEMINI_MODEL=gemini-2.0-flash
# COCODE_API_TEST_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# COCODE_API_TEST_GEMINI_CAPABILITIES=text,streaming,tools,cross_provider

# ============================================================================
# Volcengine Ark
# ============================================================================
# COCODE_API_TEST_VOLCENGINE_API_KEY=
# COCODE_API_TEST_VOLCENGINE_MODEL=
# COCODE_API_TEST_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================================================
# Z.AI / ZhipuAI
# ============================================================================
# COCODE_API_TEST_ZAI_API_KEY=
# COCODE_API_TEST_ZAI_MODEL=
# COCODE_API_TEST_ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# ============================================================================
# OpenAI-Compatible (for xAI, Groq, Together, DeepSeek, etc.)
# ============================================================================
# COCODE_API_TEST_OPENAI_COMPAT_API_KEY=
# COCODE_API_TEST_OPENAI_COMPAT_MODEL=
# COCODE_API_TEST_OPENAI_COMPAT_BASE_URL=   # Required for OpenAI-compatible

# ============================================================================
# Full JSON Config Example (MODE 2)
# ============================================================================
# COCODE_API_TEST_VOLCENGINE_CONFIG={"name":"volcengine","api":"volcengine","base_url":"https://ark.cn-beijing.volces.com/api/v3","api_key":"xxx"}

# ============================================================================
# Global Settings
# ============================================================================
# Restrict capabilities for ALL providers (comma-separated).
# Available: text, streaming, tools, cross_provider
# Default: all enabled
# COCODE_API_TEST_CAPABILITIES=text,streaming,tools
