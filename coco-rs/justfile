set positional-arguments

# Display help
help:
    just -l

# ============================================================================
# Development
# ============================================================================

# Format code
fmt:
    #!/usr/bin/env bash
    # imports_granularity is nightly-only; filter the harmless stable warning.
    cargo fmt 2> >(grep -v 'imports_granularity = Item' >&2 || true)

# Check all crates (lib + bin)
check *args:
    cargo check "$@"

# Check that tests compile too. Catches breakage in `*.test.rs` files
# without paying the cost of running them. Run before `clippy` / `test`
# so test compile errors surface in seconds, not minutes.
check-tests *args:
    cargo check --workspace --tests "$@"

# Build all crates
build *args:
    cargo build "$@"

# Run clippy on all crates (workspace-wide)
clippy *args:
    bash "{{justfile_directory()}}/../.claude/scripts/clippy.sh" --full "$@"

# Run clippy only on crates affected by uncommitted changes (incl. transitive
# reverse-dep closure). Falls back to full when Cargo.toml/Cargo.lock change
# or affected ≥ 70% of workspace.
clippy-affected *args:
    bash "{{justfile_directory()}}/../.claude/scripts/clippy.sh" --incremental --head "$@"

# Fix clippy warnings. Flag set MUST match `clippy.sh --full` (same
# `--all-features --tests`) so `fix` can't auto-edit code into a state
# clippy still reports. Caller scopes via `-p coco-<name>` to a single
# crate; the workspace-wide form lives in `clippy-affected` instead.
fix *args:
    cargo clippy --fix --all-features --tests --allow-dirty "$@"

# Install dependencies
install:
    rustup show active-toolchain
    cargo fetch

# ============================================================================
# Testing
# ============================================================================

# Run all tests (nextest, faster than cargo test)
test *args:
    cargo nextest run --no-fail-fast "$@"

# Test a specific crate
test-crate crate *args:
    cargo test -p {{crate}} "$@"

# ============================================================================
# Pre-commit
# ============================================================================

# Enforce: vercel-ai-provider may only be imported by services/inference
# (the re-export seam) and common/types. Every other crate must reach AI
# SDK types via `coco_inference::*` aliases — see
# services/inference/src/lib.rs for the canonical list.
check-seam:
    bash "{{justfile_directory()}}/scripts/check-vercel-ai-seam.sh"

# Fast validation: same chain as `pre-commit` minus the test run. Use
# during iteration when you want fmt + seam guard + clippy (which is a
# superset of `cargo check`) but don't yet need to pay for nextest.
# Promote to `pre-commit` before committing.
quick-check: fmt check-seam clippy-affected

# REQUIRED before commit. Uses incremental clippy (changed crates + reverse-dep
# closure) to avoid recompiling the whole workspace on small commits. Falls
# back to full when Cargo.toml/Cargo.lock change.
#
# Prefer this over running fmt/check/clippy/test individually: clippy is a
# superset of `cargo check`, and `test` compiles everything `clippy --tests`
# already linted, so the manual chain just duplicates work. For iteration
# without a test run, use `quick-check`.
pre-commit: fmt check-seam clippy-affected test

# ============================================================================
# Running
# ============================================================================

# Run coco CLI
alias c := coco
coco *args:
    cargo run --bin coco -- "$@"
