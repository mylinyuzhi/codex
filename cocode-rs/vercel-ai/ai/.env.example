# vercel-ai Integration Test Configuration
#
# Copy this file to `.env.test` (or `.env`) and fill in your API keys.
# Tests will gracefully skip providers that are not configured.
#
# Loading priority:
#   1. VERCEL_AI_TEST_ENV_FILE env var (custom path)
#   2. .env.test (in this directory)
#   3. .env (in this directory)
#
# URL suffix auto-detect:
#   The SDK auto-appends API paths (e.g., /chat/completions, /responses, /messages)
#   to BASE_URL. If BASE_URL already ends with the path, appending is skipped
#   automatically. Set FULL_URL=true to disable suffix appending entirely.
#
# User-Agent:
#   Some gateways (e.g., DashScope coding.dashscope) reject requests without
#   a User-Agent header. Set USER_AGENT per-provider to add one:
#   VERCEL_AI_TEST_OPENAI_CHAT_USER_AGENT=vercel-ai/0.0.0

# ============================================================================
# OpenAI
# ============================================================================
# When configured, tests run BOTH Chat Completions API and Responses API
# variants automatically (openai_chat + openai_responses).
#
# Shared config (used by both variants unless overridden):
VERCEL_AI_TEST_OPENAI_API_KEY=
VERCEL_AI_TEST_OPENAI_MODEL=gpt-4o-mini
# VERCEL_AI_TEST_OPENAI_BASE_URL=          # Optional: custom endpoint
# VERCEL_AI_TEST_OPENAI_CAPABILITIES=text,streaming,tools,vision,cross_provider
#
# Per-variant overrides (optional):
# Each variant can override API_KEY, MODEL, BASE_URL, CAPABILITIES, and
# APPEND_PATH_SUFFIX independently. Useful when Chat Completions and Responses
# APIs use different endpoints/models (e.g., DashScope).
#
# VERCEL_AI_TEST_OPENAI_CHAT_API_KEY=
# VERCEL_AI_TEST_OPENAI_CHAT_MODEL=qwen-plus
# VERCEL_AI_TEST_OPENAI_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VERCEL_AI_TEST_OPENAI_CHAT_CAPABILITIES=text,streaming,tools,vision,cross_provider
#
# VERCEL_AI_TEST_OPENAI_RESPONSES_API_KEY=
# VERCEL_AI_TEST_OPENAI_RESPONSES_MODEL=qwen3.5-plus
# VERCEL_AI_TEST_OPENAI_RESPONSES_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
# VERCEL_AI_TEST_OPENAI_RESPONSES_CAPABILITIES=text,streaming,tools,vision,cross_provider
#
# To disable a variant entirely, set capabilities to "none":
# VERCEL_AI_TEST_OPENAI_RESPONSES_CAPABILITIES=none

# ============================================================================
# OpenAI-Compatible (for xAI, Groq, Together, Fireworks, DeepSeek, etc.)
# ============================================================================
# Uses Chat Completions API only.
VERCEL_AI_TEST_OPENAI_COMPATIBLE_API_KEY=
VERCEL_AI_TEST_OPENAI_COMPATIBLE_MODEL=
VERCEL_AI_TEST_OPENAI_COMPATIBLE_BASE_URL=
# VERCEL_AI_TEST_OPENAI_COMPATIBLE_CAPABILITIES=text,streaming,tools

# ============================================================================
# Anthropic
# ============================================================================
VERCEL_AI_TEST_ANTHROPIC_API_KEY=
VERCEL_AI_TEST_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# VERCEL_AI_TEST_ANTHROPIC_BASE_URL=       # Optional: custom endpoint
# VERCEL_AI_TEST_ANTHROPIC_CAPABILITIES=text,streaming,tools,vision,cross_provider

# ============================================================================
# Google Generative AI (Gemini)
# ============================================================================
VERCEL_AI_TEST_GOOGLE_API_KEY=
VERCEL_AI_TEST_GOOGLE_MODEL=gemini-2.0-flash
# VERCEL_AI_TEST_GOOGLE_BASE_URL=          # Optional: custom endpoint
# VERCEL_AI_TEST_GOOGLE_CAPABILITIES=text,streaming,tools,vision,cross_provider

# ============================================================================
# Global Settings
# ============================================================================
# Restrict which test categories run for ALL providers (comma-separated).
# Available: text, streaming, tools, vision, cross_provider
# Default: all enabled
# VERCEL_AI_TEST_CAPABILITIES=text,streaming,tools
#
# Cross-provider tests dynamically discover all configured providers with
# the cross_provider capability and test all pairs (source -> target).
# At least 2 configured providers with cross_provider are required.
