# Copy this file to `.env` (or `.env.test`) inside `coco-sdk/python/tests/e2e/`.
# The conftest also reads `coco-rs/tests/live/.env[.test]` so a single
# credentials file works for both the Rust and Python live suites.

# ─── Required for the deepseek e2e tests ────────────────────────────
# The same key powers `deepseek-openai` and `deepseek-anthropic`.
# When unset, every deepseek e2e test prints `[skip]` and is marked
# skipped (not failed) — matches the Rust `require_live!` convention.
DEEPSEEK_API_KEY=sk-...

# ─── Optional ───────────────────────────────────────────────────────
# Override the coco binary path (defaults to PATH / ~/.cargo/bin / /usr/local/bin).
# COCO_PATH=/abs/path/to/coco
