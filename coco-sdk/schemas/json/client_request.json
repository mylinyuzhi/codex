  "$defs": {
    "AgentInterruptCurrentWorkParams": {
      "description": "Params for `agent/interruptCurrentWork`.\n\nMirrors TS's teammate Escape path: abort the target teammate's\ncurrent model/tool turn while keeping the teammate process alive for\nlater messages.",
      "type": "object",
      "properties": {
        "agent_id": {
          "type": "string"
        }
      },
      "required": [
        "agent_id"
      ]
    },
    "AgentMcpServerSpec": {
      "description": "One entry in `AgentDefinition.mcp_servers`. Mirrors the TS union:\neither a `string` (reference to an existing MCP server config) or\nan inline `{name: config}` mapping that stands up a dynamic\nserver scoped to this agent. Inline configs are stored as\n`serde_json::Value` because the underlying `McpServerConfig`\nshape lives in `coco-mcp` (a higher layer that depends on\n`coco-types`); keeping it as opaque JSON avoids a back-edge.\n\nTS: `tools/AgentTool/loadAgentsDir.ts:58 AgentMcpServerSpec`.",
      "anyOf": [
        {
          "description": "Reference an existing MCP server by name (TS `string` arm).",
          "type": "string"
        },
        {
          "description": "Inline definition `{name: config}` (TS record arm). The map\nalways carries exactly one entry — the server name → its\n`McpServerConfig` JSON. TS validates this with Zod on load.",
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "ApprovalDecision": {
      "description": "TS uses `allow` / `deny` / `ask` for the canUseTool response flow.",
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "ApprovalResolveParams": {
      "description": "Matches TS `SDKControlPermissionRequestSchema` response shape flipped —\nhere the SDK is *resolving* an approval request, so it's sent\nclient→server.",
      "type": "object",
      "properties": {
        "content_blocks": {
          "description": "Optional content blocks (typically image attachments) the SDK\nclient wants attached to the next user message. Mirrors TS\n`contentBlocks?: ContentBlockParam[]` on `PermissionAllowDecision`\n(`types/permissions.ts:183`) — paste-image-during-AskUserQuestion\nor attachments alongside `MCPTool` answers ride this slot.\nCarried verbatim as `serde_json::Value` because the underlying\n`ContentBlockParam` is Anthropic-shaped; consumers translate\nper provider.",
          "type": [
            "array",
            "null"
          ],
          "items": true
        },
        "decision": {
          "$ref": "#/$defs/ApprovalDecision"
        },
        "feedback": {
          "description": "Optional feedback to inject back to the model.",
          "type": [
            "string",
            "null"
          ]
        },
        "permission_update": {
          "description": "Optional permission update to persist to rules.",
          "anyOf": [
            {
              "$ref": "#/$defs/PermissionUpdate"
            },
            {
              "type": "null"
            }
          ]
        },
        "request_id": {
          "type": "string"
        },
        "updated_input": {
          "description": "Optional rewritten tool input the SDK client supplies at\napproval time. When `Some`, the engine substitutes this for the\nmodel-emitted input before invoking the tool. Used by\n`AskUserQuestion` to ship user-selected `answers` (and optional\n`annotations`) back into the tool's data envelope.\n\nProtocol mirror of `coco_tool_runtime::ToolPermissionResolution.updated_input`\n(the in-process equivalent for TUI mode). TS parity:\n`permissionDecision.updatedInput` at `services/tools/toolExecution.ts:1130-1131`.\nConsumed by `app/cli/src/sdk_server/approval_bridge.rs`."
        }
      },
      "required": [
        "request_id",
        "decision"
      ]
    },
    "CancelRequestParams": {
      "description": "Params for `control/cancelRequest`.",
      "type": "object",
      "properties": {
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "request_id": {
          "type": "string"
        }
      },
      "required": [
        "request_id"
      ]
    },
    "ConfigApplyFlagsParams": {
      "description": "Matches TS `SDKControlApplyFlagSettingsRequestSchema` (controlSchemas.ts:467-472).",
      "type": "object",
      "properties": {
        "settings": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "settings"
      ]
    },
    "ConfigWriteParams": {
      "description": "Params for `config/value/write`.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "scope": {
          "description": "Optional scope: \"user\" | \"project\" | \"local\".",
          "type": [
            "string",
            "null"
          ]
        },
        "value": true
      },
      "required": [
        "key",
        "value"
      ]
    },
    "ElicitationResolveParams": {
      "description": "Params for `elicitation/resolve`.\n\nSent client→server in response to a prior `ServerRequest` that\nasked the client to collect structured input on behalf of an MCP\nserver (form values, OAuth tokens, etc.). The client populates\n`values` with the user's input and sets `approved=true`, or sets\n`approved=false` to reject the elicitation.\n\nTS reference: `SDKControlElicitationRequestSchema` (controlSchemas.ts)\n— TS uses a single bidirectional message that carries both request\nand response shapes; coco-rs splits them into a `ServerRequest` for\nthe ask and this params struct for the reply.",
      "type": "object",
      "properties": {
        "approved": {
          "description": "Whether the user approved the elicitation. If `false`, `values`\nis ignored and the MCP server sees a rejection.",
          "type": "boolean"
        },
        "mcp_server_name": {
          "description": "Which MCP server the elicitation originated from. Echoed back\nso the agent can route the resolution to the right connection.",
          "type": "string"
        },
        "request_id": {
          "description": "Correlation id matching the `ServerRequest` the agent sent.",
          "type": "string"
        },
        "values": {
          "description": "The collected field values keyed by field name. Each value is\nan opaque JSON payload so typed/untyped fields share the wire\nformat. Empty when `approved=false`.",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "required": [
        "request_id",
        "mcp_server_name",
        "approved"
      ]
    },
    "HookCallbackMatcher": {
      "description": "Matches TS `SDKHookCallbackMatcherSchema` (controlSchemas.ts:43-51).",
      "type": "object",
      "properties": {
        "hook_callback_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matcher": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeout": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        }
      },
      "required": [
        "hook_callback_ids"
      ]
    },
    "InitializeParams": {
      "description": "Matches TS `SDKControlInitializeRequestSchema` (controlSchemas.ts:57-71).\n\nSent once at session start for capability negotiation. Carries hooks,\nSDK MCP servers, output format, system prompt, and agent definitions\nso the agent can construct its registries before the first turn.",
