{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientRequest",
  "description": "Requests from a client to the server.",
  "oneOf": [
    {
      "description": "Start a new session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "session/start"
          ]
        },
        "params": {
          "$ref": "#/definitions/SessionStartRequestParams"
        }
      }
    },
    {
      "description": "Resume an existing session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "session/resume"
          ]
        },
        "params": {
          "$ref": "#/definitions/SessionResumeRequestParams"
        }
      }
    },
    {
      "description": "Start a new turn with user input.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "turn/start"
          ]
        },
        "params": {
          "$ref": "#/definitions/TurnStartRequestParams"
        }
      }
    },
    {
      "description": "Interrupt the current turn.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "turn/interrupt"
          ]
        },
        "params": {
          "$ref": "#/definitions/TurnInterruptRequestParams"
        }
      }
    },
    {
      "description": "Resolve a pending approval request.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "approval/resolve"
          ]
        },
        "params": {
          "$ref": "#/definitions/ApprovalResolveRequestParams"
        }
      }
    },
    {
      "description": "Respond to a user input request (e.g., AskUserQuestion tool).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "input/resolveUserInput"
          ]
        },
        "params": {
          "$ref": "#/definitions/UserInputResolveRequestParams"
        }
      }
    },
    {
      "description": "Change the model during a session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/setModel"
          ]
        },
        "params": {
          "$ref": "#/definitions/SetModelRequestParams"
        }
      }
    },
    {
      "description": "Change the permission mode during a session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/setPermissionMode"
          ]
        },
        "params": {
          "$ref": "#/definitions/SetPermissionModeRequestParams"
        }
      }
    },
    {
      "description": "Stop a running background task.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/stopTask"
          ]
        },
        "params": {
          "$ref": "#/definitions/StopTaskRequestParams"
        }
      }
    },
    {
      "description": "Respond to an SDK hook callback.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "hook/callbackResponse"
          ]
        },
        "params": {
          "$ref": "#/definitions/HookCallbackResponseParams"
        }
      }
    },
    {
      "description": "Change thinking configuration during a session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/setThinking"
          ]
        },
        "params": {
          "$ref": "#/definitions/SetThinkingRequestParams"
        }
      }
    },
    {
      "description": "Rewind files to a previous turn's state.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/rewindFiles"
          ]
        },
        "params": {
          "$ref": "#/definitions/RewindFilesRequestParams"
        }
      }
    },
    {
      "description": "Update environment variables during a session.",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/updateEnv"
          ]
        },
        "params": {
          "$ref": "#/definitions/UpdateEnvRequestParams"
        }
      }
    },
    {
      "description": "Keepalive signal (prevents idle timeouts).",
      "type": "object",
      "required": [
        "method",
        "params"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "control/keepAlive"
          ]
        },
        "params": {
          "$ref": "#/definitions/KeepAliveRequestParams"
        }
      }
    }
  ],
  "definitions": {
    "AgentDefinitionConfig": {
      "description": "Agent definition for SDK-provided custom agents.",
      "type": "object",
      "properties": {
        "background": {
          "description": "Whether the agent defaults to background execution.",
          "default": false,
          "type": "boolean"
        },
        "color": {
          "description": "Display color hint (e.g., \"cyan\", \"blue\", \"green\", \"orange\").",
          "type": [
            "string",
            "null"
          ]
        },
        "critical_reminder": {
          "description": "Critical reminder prepended to the agent's prompt.",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "description": "Short description of when to use this agent.",
          "type": [
            "string",
            "null"
          ]
        },
        "disallowed_tools": {
          "description": "Tool blacklist.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "fork_context": {
          "description": "Whether to fork the parent conversation context to this agent.",
          "default": false,
          "type": "boolean"
        },
        "hooks": {
          "description": "Hook definitions scoped to this agent.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/AgentHookConfig"
          }
        },
        "isolation": {
          "description": "Isolation mode for the agent's execution environment.",
          "anyOf": [
            {
              "$ref": "#/definitions/AgentIsolationMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "max_turns": {
          "description": "Maximum turns.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "mcp_servers": {
          "description": "MCP server name references required by this agent.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "memory": {
          "description": "Memory scope for persistent agent memory.",
          "anyOf": [
            {
              "$ref": "#/definitions/AgentMemoryScope"
            },
            {
              "type": "null"
            }
          ]
        },
        "model": {
          "description": "Model override.",
          "type": [
            "string",
            "null"
          ]
        },
        "permission_mode": {
          "description": "Permission mode override (e.g., \"default\", \"bypassPermissions\").",
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "description": "System prompt or instructions.",
          "type": [
            "string",
            "null"
          ]
        },
        "skills": {
          "description": "Skill names to load for this agent.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "tools": {
          "description": "Tool whitelist.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "use_custom_prompt": {
          "description": "Whether `prompt` replaces the entire system prompt (true) or appends (false).",
          "default": false,
          "type": "boolean"
        }
      }
    },
    "AgentHookConfig": {
      "description": "A hook definition scoped to an agent.",
      "type": "object",
      "required": [
        "command",
        "event"
      ],
      "properties": {
        "command": {
          "description": "The command to execute.",
          "type": "string"
        },
        "event": {
          "description": "The event type (e.g., \"PreToolUse\", \"PostToolUse\", \"Stop\").",
          "type": "string"
        },
        "matcher": {
          "description": "Optional matcher pattern (e.g., tool name).",
          "type": [
            "string",
            "null"
          ]
        },
        "timeout": {
          "description": "Optional timeout in seconds.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      }
    },
    "AgentIsolationMode": {
      "description": "Isolation mode for agent execution environment.",
      "oneOf": [
        {
          "description": "No isolation — agent shares parent's working directory.",
          "type": "string",
          "enum": [
            "none"
          ]
        },
        {
          "description": "Git worktree isolation — agent runs in a detached worktree.",
          "type": "string",
          "enum": [
            "worktree"
          ]
        }
      ]
    },
    "AgentMemoryScope": {
      "description": "Memory scope for persistent agent memory.",
      "oneOf": [
        {
          "description": "User-level memory.",
          "type": "string",
          "enum": [
            "user"
          ]
        },
        {
          "description": "Project-level memory.",
          "type": "string",
          "enum": [
            "project"
          ]
        },
        {
          "description": "Local (gitignored) memory.",
          "type": "string",
          "enum": [
            "local"
          ]
        }
      ]
    },
    "ApprovalDecision": {
      "description": "Decision on an approval request.",
      "oneOf": [
        {
          "description": "Approve the tool execution.",
          "type": "string",
          "enum": [
            "approve"
          ]
        },
        {
          "description": "Approve for this session (don't ask again for this tool).",
          "type": "string",
          "enum": [
            "approve_session"
          ]
        },
        {
          "description": "Deny the tool execution.",
          "type": "string",
          "enum": [
            "deny"
          ]
        },
        {
          "description": "Approve with modified tool input.",
          "type": "string",
          "enum": [
            "modify"
          ]
        }
      ]
    },
    "ApprovalResolveRequestParams": {
      "description": "Parameters for `approval/resolve`.",
      "type": "object",
      "required": [
        "decision",
        "request_id"
      ],
      "properties": {
        "decision": {
          "description": "The decision.",
          "allOf": [
            {
              "$ref": "#/definitions/ApprovalDecision"
            }
          ]
        },
        "request_id": {
          "description": "The request ID of the approval being resolved.",
          "type": "string"
        },
        "updated_input": {
          "description": "Modified tool input (required when decision is `modify`)."
        }
      }
    },
    "HookCallbackConfig": {
      "description": "SDK hook callback configuration.\n\nPre-registered at initialize time following the Claude Agent SDK pattern. When a hook event fires, the server emits `ServerRequest::HookCallback` with the callback_id, and the SDK client responds.",
      "type": "object",
      "required": [
        "callback_id",
        "event"
      ],
      "properties": {
        "callback_id": {
          "description": "Unique callback identifier (UUID, pre-registered at init).",
          "type": "string"
        },
        "event": {
          "description": "Hook event type (e.g., \"PreToolUse\", \"PostToolUse\").",
          "type": "string"
        },
        "matcher": {
          "description": "Tool name pattern to match (glob-style, None = all tools).",
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_ms": {
          "description": "Timeout in milliseconds for the callback response.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      }
    },
    "HookCallbackResponseParams": {
      "description": "Parameters for `hook/callbackResponse`.",
      "type": "object",
      "required": [
        "request_id"
      ],
      "properties": {
        "error": {
          "description": "Error message if the callback failed.",
          "type": [
            "string",
            "null"
          ]
        },
        "output": {
          "description": "Hook output payload.",
          "default": null
        },
        "request_id": {
          "description": "The request_id from the corresponding HookCallback.",
          "type": "string"
        }
      }
    },
    "KeepAliveRequestParams": {
      "description": "Parameters for `control/keepAlive`.",
      "type": "object",
      "properties": {
        "timestamp": {
          "description": "Optional timestamp (milliseconds since epoch).",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        }
      }
    },
    "McpServerConfig": {
      "description": "MCP server configuration for SDK clients.",
      "oneOf": [
        {
          "description": "Subprocess-based MCP server (stdio transport).",
          "type": "object",
          "required": [
            "command",
            "type"
          ],
          "properties": {
            "args": {
              "description": "Command arguments.",
              "default": [],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "command": {
              "description": "Command to run.",
              "type": "string"
            },
            "env": {
              "description": "Environment variables.",
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "stdio"
              ]
            }
          }
        },
        {
          "description": "SSE-based MCP server.",
          "type": "object",
          "required": [
            "type",
            "url"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "sse"
              ]
            },
            "url": {
              "description": "Server URL.",
              "type": "string"
            }
          }
        },
        {
          "description": "HTTP-based MCP server.",
          "type": "object",
          "required": [
            "type",
            "url"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "http"
              ]
            },
            "url": {
              "description": "Server URL.",
              "type": "string"
            }
          }
        }
      ]
    },
    "OutputFormatConfig": {
      "description": "Output format configuration for structured output.",
      "type": "object",
      "required": [
        "schema"
      ],
      "properties": {
        "schema": {
          "description": "JSON Schema for the expected output."
        }
      }
    },
    "RewindFilesRequestParams": {
      "description": "Parameters for `control/rewindFiles`.",
      "type": "object",
      "required": [
        "turn_id"
      ],
      "properties": {
        "turn_id": {
          "description": "Turn ID to rewind files to.",
          "type": "string"
        }
      }
    },
    "SandboxConfig": {
      "description": "Sandbox configuration.",
      "type": "object",
      "properties": {
        "auto_allow_bash_if_sandboxed": {
          "description": "Auto-allow Bash tool when sandboxed (avoids approval prompts).",
          "default": false,
          "type": "boolean"
        },
        "exclude_commands": {
          "description": "Commands excluded from sandbox restrictions.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode": {
          "description": "Sandbox mode.",
          "default": "none",
          "allOf": [
            {
              "$ref": "#/definitions/SandboxMode"
            }
          ]
        },
        "network_access": {
          "description": "Whether to allow network access in sandbox.",
          "default": false,
          "type": "boolean"
        }
      }
    },
    "SandboxMode": {
      "description": "Sandbox execution mode.",
      "oneOf": [
        {
          "description": "No sandboxing.",
          "type": "string",
          "enum": [
            "none"
          ]
        },
        {
          "description": "Read-only filesystem access.",
          "type": "string",
          "enum": [
            "read_only"
          ]
        },
        {
          "description": "Strict sandboxing.",
          "type": "string",
          "enum": [
            "strict"
          ]
        }
      ]
    },
    "SessionResumeRequestParams": {
      "description": "Parameters for `session/resume`.",
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "prompt": {
          "description": "New prompt to send in the resumed session.",
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "description": "Session ID to resume.",
          "type": "string"
        }
      }
    },
    "SessionStartRequestParams": {
      "description": "Parameters for `session/start`.",
      "type": "object",
      "required": [
        "prompt"
      ],
      "properties": {
        "agents": {
          "description": "Custom sub-agent definitions.",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "$ref": "#/definitions/AgentDefinitionConfig"
          }
        },
        "cwd": {
          "description": "Working directory override.",
          "type": [
            "string",
            "null"
          ]
        },
        "disable_builtin_agents": {
          "description": "Disable all built-in agent definitions.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "env": {
          "description": "Environment variables to set.",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "hooks": {
          "description": "SDK hook callbacks (pre-registered at session start).",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/HookCallbackConfig"
          }
        },
        "max_budget_cents": {
          "description": "Maximum budget in cents before stopping.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "max_turns": {
          "description": "Maximum turns before stopping.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "mcp_servers": {
          "description": "MCP server configurations.",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "$ref": "#/definitions/McpServerConfig"
          }
        },
        "model": {
          "description": "Model override (e.g., \"sonnet\", \"opus\").",
          "type": [
            "string",
            "null"
          ]
        },
        "output_format": {
          "description": "Structured output JSON schema.",
          "anyOf": [
            {
              "$ref": "#/definitions/OutputFormatConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "permission_mode": {
          "description": "Permission mode override.",
          "type": [
            "string",
            "null"
          ]
        },
        "permission_rules": {
          "description": "Permission rules.",
          "type": [
            "array",
            "null"
          ],
          "items": true
        },
        "prompt": {
          "description": "Initial prompt to send.",
          "type": "string"
        },
        "sandbox": {
          "description": "Sandbox configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/SandboxConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "system_prompt": {
          "description": "Full system prompt override or structured config.",
          "anyOf": [
            {
              "$ref": "#/definitions/SystemPromptConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "system_prompt_suffix": {
          "description": "System prompt suffix (appended to built-in system prompt).",
          "type": [
            "string",
            "null"
          ]
        },
        "thinking": {
          "description": "Thinking/reasoning configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/ThinkingConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "tools": {
          "description": "Tool whitelist or preset configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/ToolsConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "SetModelRequestParams": {
      "description": "Parameters for `control/setModel`.",
      "type": "object",
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "description": "Model identifier (e.g., \"sonnet\", \"opus\", \"haiku\").",
          "type": "string"
        }
      }
    },
    "SetPermissionModeRequestParams": {
      "description": "Parameters for `control/setPermissionMode`.",
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "description": "Permission mode (e.g., \"default\", \"acceptEdits\", \"bypassPermissions\").",
          "type": "string"
        }
      }
    },
    "SetThinkingRequestParams": {
      "description": "Parameters for `control/setThinking`.",
      "type": "object",
      "required": [
        "thinking"
      ],
      "properties": {
        "thinking": {
          "description": "Thinking configuration to apply.",
          "allOf": [
            {
              "$ref": "#/definitions/ThinkingConfig"
            }
          ]
        }
      }
    },
    "StopTaskRequestParams": {
      "description": "Parameters for `control/stopTask`.",
      "type": "object",
      "required": [
        "task_id"
      ],
      "properties": {
        "task_id": {
          "description": "Task ID to stop.",
          "type": "string"
        }
      }
    },
    "SystemPromptConfig": {
      "description": "System prompt configuration.",
      "anyOf": [
        {
          "description": "Raw system prompt string.",
          "type": "string"
        },
        {
          "description": "Structured system prompt with preset and optional append.",
          "type": "object",
          "required": [
            "preset"
          ],
          "properties": {
            "append": {
              "description": "Text to append to the preset.",
              "type": [
                "string",
                "null"
              ]
            },
            "preset": {
              "description": "Base preset to use.",
              "type": "string"
            }
          }
        }
      ]
    },
    "ThinkingConfig": {
      "description": "Thinking / reasoning configuration.",
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "max_tokens": {
          "description": "Maximum thinking tokens (if applicable).",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "mode": {
          "description": "Thinking mode.",
          "allOf": [
            {
              "$ref": "#/definitions/ThinkingMode"
            }
          ]
        }
      }
    },
    "ThinkingMode": {
