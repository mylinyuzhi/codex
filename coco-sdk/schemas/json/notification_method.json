    "session/started",
    "session/result",
    "session/ended",
    "session/usageUpdated",
    "history/messageAppended",
    "history/messageTruncated",
    "history/resetForResume",
    "history/replaced",
    "history/reasoningMetadataAttached",
    "turn/started",
    "turn/ended",
    "item/started",
    "item/updated",
    "item/completed",
    "agentMessage/delta",
    "reasoning/delta",
    "mcp/startupStatus",
    "mcp/startupComplete",
    "lsp/prewarmComplete",
    "context/compacted",
    "context/usageWarning",
    "context/compactionStarted",
    "context/compactionPhase",
    "context/compactionFailed",
    "context/cleared",
    "task/started",
    "task/completed",
    "task/progress",
    "task_panel/changed",
    "plan_approval/requested",
    "agents/killed",
    "model/fallbackStarted",
    "model/fallbackCompleted",
    "model/fastModeChanged",
    "model/roleChanged",
    "permission/modeChanged",
    "prompt/suggestion",
    "error",
    "rateLimit",
    "keepAlive",
    "ide/selectionChanged",
    "ide/diagnosticsUpdated",
    "plan/modeChanged",
    "queue/stateChanged",
    "queue/commandQueued",
    "queue/commandDequeued",
    "rewind/completed",
    "rewind/failed",
    "cost/warning",
    "sandbox/stateChanged",
    "sandbox/violationsDetected",
    "agents/registered",
    "hook/started",
    "hook/progress",
    "hook/response",
    "worktree/entered",
    "worktree/exited",
    "summarize/completed",
    "summarize/failed",
    "stream/stallDetected",
    "stream/watchdogWarning",
    "stream/requestEnd",
    "session/stateChanged",
    "localCommand/output",
    "files/persisted",
    "elicitation/complete",
    "tool/useSummary",
    "tool/progress",
    "plugins/changed"
  ]
}