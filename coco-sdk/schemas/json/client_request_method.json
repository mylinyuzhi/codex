{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientRequestMethod",
  "description": "Wire-method identifier for every `ClientRequest` variant.\n\nCross-language protocol constant exported to the JSON schema bundle so Python / other SDK codegens obtain the same vocabulary. Consumers should reference `ClientRequestMethod::SessionStart` rather than compare against raw wire strings.",
  "type": "string",
  "enum": [
    "initialize",
    "session/start",
    "session/resume",
    "session/list",
    "session/read",
    "session/archive",
    "turn/start",
    "turn/interrupt",
    "approval/resolve",
    "input/resolveUserInput",
    "elicitation/resolve",
    "control/setModel",
    "control/setPermissionMode",
    "control/setThinking",
    "control/stopTask",
    "control/rewindFiles",
    "control/updateEnv",
    "control/keepAlive",
    "control/cancelRequest",
    "config/read",
    "config/value/write",
    "hook/callbackResponse",
    "mcp/routeMessageResponse",
    "mcp/status",
    "context/usage",
    "mcp/setServers",
    "mcp/reconnect",
    "mcp/toggle",
    "plugin/reload",
    "config/applyFlags"
  ]
}