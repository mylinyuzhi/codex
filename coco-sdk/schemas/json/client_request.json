    "PermissionUpdateDestination": {
      "description": "Destination for persisting permission updates.\n\nPersistable destinations (`User`/`Project`/`LocalSettings`) write to\ndisk; in-memory destinations (`Session`/`CliArg`/`Command`) live only\nfor the running session. TS parity: same split as\n`persistPermissionUpdates` in `PermissionUpdate.ts`.\n\n`Command` is reserved for rules contributed by an invoked command or\nskill's frontmatter (`allowed-tools:`). TS parity:\n`alwaysAllowRules.command` populated by `SkillTool` /\n`createGetAppStateWithAllowedTools`.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "user_settings",
            "project_settings",
            "local_settings",
            "session",
            "cli_arg"
          ]
        },
        {
          "description": "Rules contributed by a command/skill frontmatter `allowed-tools`.\nIn-memory only; cleared on session end.",
          "type": "string",
          "const": "command"
        }
      ]
    },
